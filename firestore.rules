rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidTransaction(data) {
      return data.keys().hasAll(['userId', 'amount', 'category', 'type', 'date']) 
        && data.keys().size() == 5 || (data.keys().size() == 6 && data.keys().hasAll(['description']))
        && data.userId == request.auth.uid
        && data.amount is number && data.amount >= 0
        && data.category is string && data.category.size() <= 100
        && data.type in ['income', 'expense']
        && (data.description == null || (data.description is string && data.description.size() <= 500))
        && data.date is timestamp;
    }

    match /transactions/{transactionId} {
      allow create: if isSignedIn() 
        && isValidId(transactionId)
        && isValidTransaction(incoming());
      
      allow update: if false; // Transactions are immutable in this app, or handle via actions if needed
      
      allow delete: if isSignedIn() 
        && isOwner(existing().userId);
      
      allow get: if isSignedIn() 
        && isOwner(existing().userId);
        
      allow list: if isSignedIn() 
        && request.query.limit <= 100
        && resource.data.userId == request.auth.uid;
    }
  }
}
